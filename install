#!/bin/bash

set -euo pipefail

/bin/sh -c "$(curl -fsSL https://github.com/koterpillar/mybox/releases/latest/download/bootstrap)"

if [[ $HOSTNAME =~ DQ94 ]]
then
  if ! [ -d local ]
  then
    git clone git@bitbucket.org:atlassian/akotlyarov-local.git local
  fi
fi

# PATH for tools might not be picked up yet
export PATH="$HOME/.local/bin:$PATH"

mybox "$@"
